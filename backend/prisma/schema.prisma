generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String           @id @default(cuid())
  email                String           @unique
  passwordHash         String?
  nickname             String           @unique
  language             Language         @default(EN)
  role                 UserRole         @default(USER)
  isActive             Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  emailVerificationOTP String?
  emailVerified        Boolean          @default(false)
  otpExpiry            DateTime?
  passwordResetExpiry  DateTime?
  passwordResetToken   String?
  avatar               String?
  provider             AuthProvider?    @default(LOCAL)
  providerId           String?
  blockedBy            Block[]          @relation("Blocked")
  blockedUsers         Block[]          @relation("Blocker")
  boardMemberships     BoardMember[]
  createdBoards        Board[]          @relation("BoardCreator")
  comments             Comment[]
  eyeMaskedImages      EyeMaskedImage[] @relation("EyeMaskedImages")
  images               Image[]
  posts                Post[]
  reports              Report[]         @relation("UserReports")
  votes                Vote[]
  sentChatMessages     ChatMessage[]    @relation("ChatMessageSender")
  receivedChatMessages ChatMessage[]    @relation("ChatMessageReceiver")

  @@unique([provider, providerId])
  @@index([email])
  @@index([nickname])
  @@index([passwordResetToken])
  @@index([provider, providerId])
  @@map("users")
}

model Board {
  id               String          @id @default(cuid())
  name             String          @unique
  description      String?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  visibilityAccess BoardVisibility @default(PUBLIC)
  categoryId       String
  creatorId        String
  members          BoardMember[]
  creator          User            @relation("BoardCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  category         BoardCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  posts            Post[]

  @@index([creatorId])
  @@index([categoryId])
  @@map("boards")
}

model BoardCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  boards    Board[]

  @@map("board_categories")
}

model Post {
  id               String    @id @default(cuid())
  title            String
  body             String?
  originalLanguage Language
  authorId         String
  boardId          String?
  postCategory     String?
  isActive         Boolean   @default(true)
  isDeleted        Boolean   @default(false)
  upvoteCount      Int       @default(0)
  downvoteCount    Int       @default(0)
  commentCount     Int       @default(0)
  viewCount        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tags             String[]  @default([])
  comments         Comment[]
  images           Image[]
  author           User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  board            Board?    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  reports          Report[]  @relation("ReportedPosts")
  votes            Vote[]

  @@index([boardId])
  @@index([authorId])
  @@index([createdAt])
  @@index([isActive, isDeleted])
  @@index([title, body])
  @@map("posts")
}

model Comment {
  id               String    @id @default(cuid())
  body             String
  originalLanguage Language
  postId           String
  authorId         String
  parentId         String?
  isActive         Boolean   @default(true)
  isDeleted        Boolean   @default(false)
  upvoteCount      Int       @default(0)
  downvoteCount    Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  author           User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent           Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies          Comment[] @relation("CommentReplies")
  post             Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  reports          Report[]  @relation("ReportedComments")
  votes            Vote[]

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([createdAt])
  @@index([body])
  @@map("comments")
}

model Vote {
  id        String   @id @default(cuid())
  type      VoteType
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime @default(now())
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@index([userId])
  @@map("votes")
}

model Report {
  id           String       @id @default(cuid())
  reason       String
  status       ReportStatus @default(PENDING)
  reportedById String
  postId       String?
  commentId    String?
  createdAt    DateTime     @default(now())
  reviewedAt   DateTime?
  reviewedBy   String?
  comment      Comment?     @relation("ReportedComments", fields: [commentId], references: [id], onDelete: Cascade)
  post         Post?        @relation("ReportedPosts", fields: [postId], references: [id], onDelete: Cascade)
  reportedBy   User         @relation("UserReports", fields: [reportedById], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([postId])
  @@index([commentId])
  @@index([createdAt])
  @@map("reports")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

model Image {
  id        String   @id @default(cuid())
  url       String
  key       String
  postId    String?
  userId    String
  size      Int?
  mimeType  String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@map("images")
}

model EyeMaskedImage {
  id        String   @id @default(cuid())
  url       String
  key       String
  userId    String
  size      Int?
  mimeType  String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  user      User     @relation("EyeMaskedImages", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("eye_masked_images")
}

model BoardMember {
  id        String            @id @default(cuid())
  userId    String
  boardId   String
  status    BoardMemberStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  board     Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, boardId])
  @@index([boardId])
  @@index([userId])
  @@index([status])
  @@map("board_members")
}

model ContactSubmission {
  id           String          @id @default(cuid())
  name         String
  email        String
  category     String
  subject      String
  message      String
  status       ContactStatus   @default(PENDING)
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  resolvedAt   DateTime?

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("contact_submissions")
}

enum ContactStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Language {
  KO
  EN
  ZH
  JA
}

enum UserRole {
  USER
  ADMIN
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

enum BoardVisibility {
  PUBLIC
  PRIVATE
  RESTRICTED
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum BoardMemberStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  text       String
  isDeleted  Boolean  @default(false)
  editedAt   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sender     User     @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ChatMessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
  @@index([createdAt])
  @@map("chat_messages")
}

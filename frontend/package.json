{
  "name": "hinobody-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development next dev -p 3000",
    "dev:fresh": "npm run clean && cross-env NODE_ENV=development next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "powershell -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next; Write-Host 'Cache cleared successfully' } else { Write-Host 'No cache to clear' }\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.952.0",
    "browser-image-compression": "^2.0.2",
    "face-api.js": "^0.22.2",
    "next": "^16.0.10",
    "next-intl": "^4.6.1",
    "next-pwa": "^5.6.0",
    "quill": "^2.0.3",
    "quill-table": "^1.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "socket.io-client": "^4.8.1"
},
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
